[Unit]
Description=CleanNet URL Classifier (Gunicorn)
After=network.target

[Service]
Type=simple
User=ec2-user
Group=ec2-user
WorkingDirectory=/opt/url-classifier
Environment="PATH=/opt/url-classifier/venv/bin"
Environment="CLEANNET_DISCOVERY=0"
Environment="TRUST_PROXY=1"
Environment="FLASK_DEBUG=0"
ExecStart=/opt/url-classifier/venv/bin/gunicorn -c gunicorn.conf.py wsgi:app
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
